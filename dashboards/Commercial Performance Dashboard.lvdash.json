{
  "datasets": [
    {
      "name": "9fe17027",
      "displayName": "01_KPI_Summary",
      "queryLines": [
        "SELECT\r\n",
        "    SUM(total_prescriptions) AS total_prescriptions,\r\n",
        "    SUM(total_calls) AS total_calls,\r\n",
        "    SUM(completed_calls) AS completed_calls,\r\n",
        "\r\n",
        "    ROUND(\r\n",
        "        SUM(completed_calls) / NULLIF(SUM(total_calls), 0),\r\n",
        "        2\r\n",
        "    ) AS overall_call_completion_rate,\r\n",
        "\r\n",
        "    COUNT(DISTINCT brand) AS total_brands,\r\n",
        "    COUNT(DISTINCT therapy_area) AS total_therapy_areas,\r\n",
        "\r\n",
        "    MAX(week_start_date) AS latest_week_start_date\r\n",
        "FROM cdl.gold.vw_brand_weekly_performance;"
      ],
      "catalog": "cdl",
      "schema": "gold"
    },
    {
      "name": "511c265a",
      "displayName": "02_Brand_Weekly_Performance",
      "queryLines": [
        "SELECT\r\n",
        "    week_start_date,\r\n",
        "    -- week_end_date,\r\n",
        "    brand,\r\n",
        "    therapy_area,\r\n",
        "    total_prescriptions,\r\n",
        "    total_calls,\r\n",
        "    completed_calls,\r\n",
        "    call_completion_rate,\r\n",
        "    rx_per_prescribing_hcp\r\n",
        "FROM cdl.gold.vw_brand_weekly_performance\r\n",
        "ORDER BY week_start_date, brand;"
      ]
    }
  ],
